# Environment
NODE_ENV=development
PORT=5000

# MongoDB Atlas (standard form recommended on Windows where SRV DNS fails)
MONGODB_URI=mongodb://user:pass@host1:27017,host2:27017/shop?ssl=true&replicaSet=...&authSource=admin&retryWrites=true&w=majority

# JWT (access = short-lived, refresh = long-lived). Use long random strings.
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Cloudinary (image upload)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Facebook Login (Settings > Basic on developers.facebook.com)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# CORS / frontend
FRONTEND_URL=http://localhost:3000

# Shop social links (khách inbox để đặt hàng)
SHOP_FACEBOOK_URL=
SHOP_INSTAGRAM_URL=
